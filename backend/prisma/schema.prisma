generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model RefreshTokens {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  ip        String?
  createdAt DateTime  @default(now())
  expiresAt DateTime  @default(dbgenerated("(now() + '7 days'::interval)"))
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  email         String          @unique
  password      String
  refreshTokens RefreshTokens[]

  profile Profile?
}

model Profile {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  name      String
  firstTime Boolean @default(true)

  role        Role?    @default(STUDENT)
  gender      Gender?
  dob         DateTime?
  nationality String?
  // idDocument  String?
  phone       String?

  parentOneName  String?
  parentOneEmail String?
  parentOnePhone String?

  churchId         String?
  church           Church? @relation("ChurchProfiles", fields: [churchId], references: [id])
  primaryForChurch Boolean @default(false)

  registrations Registration[]
}

model Church {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name    String
  country String
  state   String

  // primaryContactName String
  // primaryContactRole String
  // primaryContactEmail String
  // primaryContactNumber String

  members Profile[] @relation("ChurchProfiles")
}

model Registration {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id])
  eventId   String
  event     Event   @relation(fields: [eventId], references: [id])

  medications String[]
  allergies   String[]
  shirtSize   ShirtSize
  swimming    Boolean
  selfPay     Boolean
  room        String?
  group       String?

  paid Boolean
}

model Event {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  eventStatus     EventStatus @default(OPEN)
  startDate      DateTime
  endDate        DateTime
  name           String
  brief          String
  maxSignUps     Int
  location       String
  schedule       Json[]
  price          Int
  earlyBirdPrice Int?
  earlyBirdDate  DateTime?

  registrations Registration[]
}

enum ShirtSize {
  XS
  S
  M
  L
  XL
  XXL
  XXXL
}

enum Gender {
  MALE
  FEMALE
}

enum Role {
  STUDENT
  LEADER
  ADMIN
}

enum EventStatus {
  OPEN
  CLOSED
  COMPLETED
}